meta {
  name: healthroom
  type: http
  seq: 1
}

get {
  url: {{staffBase}}SMT/HealthRoomVisits
  body: json
  auth: bearer
}

auth:bearer {
  token: {{staffToken}}
}

body:json {
  {
      "SessionId": {{ACADYEAR}},
      "SiteId": {{SITEID}},
      "UserSysId": {{USERSYSID}}
      // ,"FromDate": "",
      // "ToDate": "",
      // "SortOrder": "",
      // "FormId": ""
  }
}

settings {
  encodeUrl: true
}

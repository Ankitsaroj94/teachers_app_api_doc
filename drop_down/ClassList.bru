  token: {{staffToken}}
}

body:json {
  {
      "StaffId": 0,
      "SiteId": 47,
      "SessionId": 640,
      "AccessLevel": 10,
      "FormId": 0,
      "UserSysId": 121173
  }
}

settings {
  encodeUrl: true
}
